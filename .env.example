# ---- 复制本文件为 .env 并填好两个 key（.env 已被 .gitignore，绝不进仓库 / 网页）----

# Anthropic（大脑）：https://console.anthropic.com/ 拿 key
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# ElevenLabs（念给你听）：https://elevenlabs.io/ 账户里拿 key
ELEVENLABS_API_KEY=xxxxxxxxxxxxxxxxxxxx

# ElevenLabs 英文音色 ID（在 elevenlabs 的 Voices 里点音色复制 Voice ID）
# 留空则用下面这个默认公共音色 "Rachel"
ELEVENLABS_VOICE_ID=OlIwv2Z2NHmIfMaCuQHJ

# ---- 出站代理（北京/墙内必填，STT/Claude/ElevenLabs 三段都在墙外）----
# 本地服务的出站请求会走这个代理。填你 Clash/Verge 的 http 端口。
# 例：HTTPS_PROXY=http://127.0.0.1:7890
HTTPS_PROXY=

# 本地服务监听端口（默认 5178）
PORT=5178

# ============ 桌宠引擎 coach-engine.js（语音 + agent 干活）============
# 转写用 Deepgram（仅 STT=deepgram 时需要；默认走 ElevenLabs Scribe，不用填）
DEEPGRAM_API_KEY=

# 启动默认模式：agent=通用助手(开全工具、能干活，默认) | coach=英语陪练(关工具)
COACH_MODE=agent
# 启动默认模型：haiku(快, 默认) | sonnet | opus。对话里说"用 opus""切到 sonnet"或打 /model opus 可随时切。
COACH_MODEL=haiku
# agent 模式干活的工作目录（在这里跑 bash / 读写文件）。默认 ~/Desktop/同步
# COACH_WORKDIR=/Users/你/某项目

# 语音「电话失真」效果：默认开。COACH_VOICE_FX=0 关掉用原声。
# 想自己调失真，改 ffmpeg 滤镜串（需装 ffmpeg）：
# COACH_VOICE_FX=1
# COACH_VOICE_FX_FILTER=highpass=f=350,lowpass=f=3400,acrusher=bits=8:samples=1:mode=log:mix=0.28,volume=2.8,alimiter=limit=0.9

# 会话记录存放目录（关掉再开 / 重启能看回上次对话）。默认 ~/.coach-sessions
# COACH_SESSION_DIR=/Users/你/.coach-sessions

# ── 语音转文字（STT）：默认本机 whisper.cpp（离线免费），检测到模型文件就自动启用
# 装：brew install whisper-cpp；下模型到 ~/.whisper-models/ggml-large-v3-turbo.bin
# COACH_STT=local            # local=本机whisper-server | scribe=ElevenLabs云端兜底
# COACH_WHISPER_MODEL=/Users/你/.whisper-models/ggml-large-v3-turbo.bin
# COACH_WHISPER_LANG=auto    # auto 自动认中英；也可 en / zh
# COACH_WHISPER_PORT=8910
